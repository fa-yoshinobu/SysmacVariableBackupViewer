<Window x:Class="SysmacXmlViewer.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About SysmacVariableBackupViewer"
        Width="700"
        Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontFamily="Yu Gothic UI, Meiryo, Microsoft YaHei, SimSun, sans-serif">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center">
            <TextBlock Text="SysmacVariableBackupViewer"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#2E2E2E" />
            <TextBlock Text="{Binding ProductVersion, StringFormat=Version {0}}"
                       Margin="0,0,0,5"
                       HorizontalAlignment="Center"
                       FontSize="16"
                       Foreground="#4A4A4A" />
            <TextBlock Text="Sysmac Studio XML Variable Backup Viewer"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"
                       FontSize="12"
                       Foreground="#666666" />
            <TextBlock Text="{Binding Copyright}"
                       Margin="0,0,0,5"
                       HorizontalAlignment="Center"
                       FontSize="10"
                       Foreground="#888888" />
            <TextBlock Text="Author: fa-yoshinobu"
                       Margin="0,0,0,5"
                       HorizontalAlignment="Center"
                       FontSize="10"
                       Foreground="#888888" />
            <TextBlock Margin="0,0,0,0"
                       HorizontalAlignment="Center"
                       FontSize="10"
                       Foreground="#888888">
                <TextBlock.Inlines>
                    <Run Foreground="#888888" Text="GitHub: " />
                    <Hyperlink NavigateUri="{Binding GitHubUrl, Mode=OneWay}"
                               Foreground="#0066CC"
                               RequestNavigate="Hyperlink_RequestNavigate"
                               TextDecorations="Underline">
                        <Run Text="{Binding GitHubUrl, Mode=OneWay}" />
                    </Hyperlink>
                </TextBlock.Inlines>
            </TextBlock>
        </StackPanel>

        <TabControl Grid.Row="2" Margin="0,10,0,10">
            <TabItem Header="Application Info">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="System Information" Margin="0,0,0,10">
                            <Grid Margin="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Target Framework:" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Margin="10,2" Text="{Binding TargetFrameworkDisplay}" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Runtime:" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,2" Text="{Binding RuntimeVersion}" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="OS Version:" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="10,2" Text="{Binding OSVersion}" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Architecture:" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="10,2" Text="{Binding Architecture}" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Build Date:" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Margin="10,2" Text="{Binding BuildDate}" />

                                <TextBlock Grid.Row="5" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Assembly Version:" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Margin="10,2" Text="{Binding AssemblyVersion}" />

                                <TextBlock Grid.Row="6" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Product Name:" />
                                <TextBlock Grid.Row="6" Grid.Column="1" Margin="10,2" Text="{Binding ProductName}" />

                                <TextBlock Grid.Row="7" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Product Version:" />
                                <TextBlock Grid.Row="7" Grid.Column="1" Margin="10,2" Text="{Binding ProductVersion}" />

                                <TextBlock Grid.Row="8" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Company:" />
                                <TextBlock Grid.Row="8" Grid.Column="1" Margin="10,2" Text="{Binding CompanyName}" />

                                <TextBlock Grid.Row="9" Grid.Column="0" Margin="0,2" FontWeight="Bold" Text="Copyright:" />
                                <TextBlock Grid.Row="9" Grid.Column="1" Margin="10,2" Text="{Binding Copyright}" />
                            </Grid>
                        </GroupBox>

                        <GroupBox Header="Features" Margin="0,0,0,10">
                            <StackPanel Margin="10">
                                <TextBlock Margin="0,2" Text="• XML backup file parsing and viewing" />
                                <TextBlock Margin="0,2" Text="• Variable data type conversion and display" />
                                <TextBlock Margin="0,2" Text="• Advanced filtering and search capabilities" />
                                <TextBlock Margin="0,2" Text="• CSV export functionality" />
                                <TextBlock Margin="0,2" Text="• High-performance data handling" />
                                <TextBlock Margin="0,2" Text="• Multi-language support" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Libraries">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="Dependencies" Margin="0,0,0,10">
                            <DataGrid ItemsSource="{Binding Libraries}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      AlternatingRowBackground="#F9F9F9"
                                      Height="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Width="250" Binding="{Binding Name}" Header="Library" />
                                    <DataGridTextColumn Width="100" Binding="{Binding Version}" Header="Version" />
                                    <DataGridTextColumn Width="150" Binding="{Binding License}" Header="License" />
                                    <DataGridTextColumn Width="*" Binding="{Binding Description}" Header="Description" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </GroupBox>

                        <GroupBox Header="Third Party Licenses" Margin="0,0,0,10">
                            <StackPanel Margin="10">
                                <TextBlock Margin="0,0,0,10"
                                           FontWeight="Bold"
                                           Text="This application uses the following third-party libraries:" />

                                <Expander Margin="0,5" Header="System.Text.Encoding.CodePages (MIT License)">
                                    <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                                        <TextBlock FontFamily="Consolas, Courier New, monospace"
                                                   FontSize="10"
                                                   Text="{Binding CodePagesLicense}"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Expander>

                                <Expander Margin="0,5" Header=".NET Runtime (MIT License)">
                                    <ScrollViewer Height="150" VerticalScrollBarVisibility="Auto">
                                        <TextBlock FontFamily="Consolas, Courier New, monospace"
                                                   FontSize="10"
                                                   Text="{Binding DotNetLicense}"
                                                   TextWrapping="Wrap" />
                                    </ScrollViewer>
                                </Expander>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="License">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <GroupBox Header="Application License" Margin="0,0,0,10">
                            <ScrollViewer Height="300" VerticalScrollBarVisibility="Auto">
                                <TextBlock FontFamily="Consolas, Courier New, monospace"
                                           FontSize="10"
                                           Text="{Binding ApplicationLicense}"
                                           TextWrapping="Wrap" />
                            </ScrollViewer>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">
            <Button Width="80"
                    Height="30"
                    Background="#F0F0F0"
                    BorderBrush="#CCCCCC"
                    BorderThickness="1"
                    Click="OkButton_Click"
                    Content="OK" />
        </StackPanel>
    </Grid>
</Window>
